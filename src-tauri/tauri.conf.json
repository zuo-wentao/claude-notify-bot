{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Notify Bot",
  "version": "0.1.0",
  "identifier": "com.claude.notify.bot",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Claude Notify Bot",
        "label": "main",
        "width": 1080,
        "height": 760,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
